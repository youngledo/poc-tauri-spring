{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Spring POC",
  "version": "1.0.0",
  "identifier": "com.example.taurispring",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri + Spring Boot POC",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "../backend/target/src-spring.jar",
      "../backend/target/src-spring"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null,
      "frameworks": [],
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Tauri + Spring Boot POC",
    "longDescription": "A proof of concept desktop application combining Tauri frontend with Spring Boot backend, supporting both JAR and Native Image modes."
  }
}
